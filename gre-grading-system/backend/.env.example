# OpenAI
OPENAI_API_KEY=your-openai-api-key

# LangSmith (for monitoring)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=gre-grading-system

# Tavily (for web search/fact-checking)
TAVILY_API_KEY=your-tavily-api-key

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/gre_grading
DATABASE_URL_SYNC=postgresql://postgres:password@localhost:5432/gre_grading

# Application
DEBUG=true
LOG_LEVEL=INFO
